# ─── IA ──────────────────────────────────────────────────────────────────────
# Google Gemini (geração de estudos, diagnóstico, enriquecimento de leads)
GOOGLE_API_KEY=AIza...
# Modelos (opcionais; têm defaults no código)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-pro
GEMINI_EXTRACT_MODEL=gemini-2.5-flash
GEMINI_EXTRACT_FALLBACK_MODEL=gemini-2.5-flash

# Anthropic (se usado em alguma rota)
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role: SOMENTE no servidor. Nunca expor no cliente.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App / URLs públicas ─────────────────────────────────────────────────────
# Domínio público estável (usado em convites, portal, share). Em produção
# aponte para o domínio real. Em dev pode usar localhost.
NEXT_PUBLIC_APP_URL=https://preceptorstudio.com
NEXT_PUBLIC_SITE_URL=https://preceptorstudio.com

# ─── Cron (Vercel) ───────────────────────────────────────────────────────────
# OBRIGATÓRIO em produção. Sem isso o cron daily-digest fica desabilitado (fail-closed).
# Gere com: openssl rand -base64 32
CRON_SECRET=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=PRECEPTOR! Studio <studio@preceptorstudio.com>

# ─── Meta Ads / Pixel + CAPI ─────────────────────────────────────────────────
# Pixel ID (default no codigo: 4342291746023127). So setar se mudar de pixel.
META_PIXEL_ID=4342291746023127
# Token de System User do Business Manager (Events Manager > Configuracoes > CAPI).
# Sem ele, o evento Lead server-side (CAPI) vira no-op. O pixel do browser segue funcionando.
META_CAPI_TOKEN=
